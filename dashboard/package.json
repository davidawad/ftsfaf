{
  "name": "ftsfaf-dashboard",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run server:dev\" \"bun run client:dev\"",
    "server:dev": "bun run --hot server/index.ts",
    "client:dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "bun run server/index.ts",
    "start": "bun run build && bun run server"
  },
  "dependencies": {
    "hono": "^4.12.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
