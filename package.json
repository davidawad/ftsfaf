{
  "name": "ftsfaf",
  "version": "0.1.0",
  "description": "TypeScript workflow orchestration engine for A2A agents",
  "type": "module",
  "bin": {
    "ftsfaf": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun x tsgo",
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "test": "bun run vitest run",
    "test:watch": "bun run vitest",
    "test:integration": "bun run vitest run tests/integration",
    "lint": "bun run eslint src --ext .ts",
    "lint:fix": "bun run eslint src --ext .ts --fix",
    "typecheck": "bun x tsgo --noEmit"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@aws-sdk/client-ec2": "^3.515.0",
    "@kubernetes/client-node": "^0.20.0",
    "bullmq": "^5.1.0",
    "commander": "^14.0.3",
    "dockerode": "^4.0.2",
    "dotenv": "^17.3.1",
    "effect": "^3.0.0",
    "express": "^4.18.2",
    "glob": "^13.0.6",
    "hono": "^4.12.7",
    "ioredis": "^5.3.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.24",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pino": "^7.0.4",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-plugin-functional": "^6.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
